        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst chatId = $('Build History').item.json.chatId;\nconst reply = $input.first().json.choices[0].message.content;\n\nstaticData.chatHistory[chatId].push({ role: 'assistant', content: reply });\n\nreturn [{ json: { chatId, reply } }];"
