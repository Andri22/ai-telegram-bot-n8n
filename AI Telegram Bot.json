    {
      "parameters": {
        "jsCode": "const message = $input.first().json.message;\nconst chatId = message.chat.id.toString();\nconst userText = message.text;\n\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.chatHistory) staticData.chatHistory = {};\nif (!staticData.chatHistory[chatId]) staticData.chatHistory[chatId] = [];\n\nstaticData.chatHistory[chatId].push({ role: 'user', content: userText });\n\nif (staticData.chatHistory[chatId].length > 10) {\n  staticData.chatHistory[chatId].shift();\n}\n\nreturn [{ json: { chatId, messages: staticData.chatHistory[chatId] } }];"
      },
